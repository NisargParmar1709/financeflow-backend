# ─────────────────────────────────────────────────────────────────────────────
# .env.example — financeflow-backend
#
# Why this file exists: Documents every environment variable the app needs.
# Copy this to .env and fill in real values. NEVER commit .env.
#
# Rule: If a variable is missing at startup, the app crashes immediately with a
# clear error message (fail-fast). It should NEVER crash mid-request because a
# config key was missing — that's a terrible user experience.
# ─────────────────────────────────────────────────────────────────────────────


# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true                   # Set to false in production — hides stack traces


# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Why asyncpg:// not postgresql://: SQLAlchemy async mode requires the asyncpg
# driver. The standard psycopg2 driver is synchronous and would block the event loop.
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require


# ── Redis (Upstash — serverless Redis) ───────────────────────────────────────
# Why rediss:// (with double 's'): Upstash requires TLS. Plain redis:// would
# fail to connect. The extra 's' enables SSL.
REDIS_URL=rediss://:password@host:port


# ── Clerk Authentication ──────────────────────────────────────────────────────
# Why we need both keys:
#   - CLERK_SECRET_KEY: Used server-side to validate JWTs via the Clerk SDK
#   - CLERK_PUBLISHABLE_KEY: Used to verify Svix webhook signatures from Clerk
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx   # Svix secret for webhook signature verification


# ── CORS Origins ──────────────────────────────────────────────────────────────
# Why comma-separated string: Pydantic Settings parses it into a list.
# In production, this should be ONLY the Vercel domain, never "*".
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://financeflow.vercel.app


# ── Cloudinary (File Storage) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key


# ── Resend (Transactional Email) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@financeflow.app


# ── Rate Limiting ─────────────────────────────────────────────────────────────
# 100 requests per minute per IP — adjust per route in production
RATE_LIMIT_PER_MINUTE=100
